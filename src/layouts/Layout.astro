---
import '../styles/global.css';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const { title = 'Amlan Kashyap — Electrical Project Engineer', description = 'Project Engineer — Electrical Transmission & Substation Projects. 132 kV substation & line execution and procurement for AEGCL, APDCL, BHEL and NTPC.' } = Astro.props;
const nav = [
  { href: `${base}/education`, label: 'Education' },
  { href: `${base}/experience`, label: 'Experience' },
  { href: `${base}/skills`, label: 'Skills' },
  { href: `${base}/research`, label: 'Research' },
  { href: 'tel:+919387975760', label: 'Contact' },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${base}/favicon.svg`} />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <div class="bg-photo" style={`background-image:url('${base}/bg.png')`}></div>
    <div class="bg-overlay"></div>

    <header>
      <div class="wrap">
        <div class="nav glass">
          <a class="brand" href={`${base}/`}>
            <span class="logo">AK</span>
            <span><b>Amlan Kashyap</b><small>Electrical Project Engineer</small></span>
          </a>
          <nav class="links">
            {nav.map((n) => <a href={n.href}>{n.label}</a>)}
          </nav>
          <a class="btn btn-primary" href={`${base}/Amlan_Kashyap_CV.pdf`} download>⬇ Download CV</a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <div class="wrap foot">
        <span>© <span id="yr"></span> Amlan Kashyap · Electrical Project Engineer · Guwahati, Assam</span>
        <a href="tel:+919387975760">+91 93879 75760</a>
      </div>
    </footer>

    <script is:inline>
      const yr = document.getElementById('yr');
      if (yr) yr.textContent = new Date().getFullYear();
    </script>
  </body>
</html>
