---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const explore = [
  { href: `${base}/education`, ic: '🎓', title: 'Education & Credentials', desc: 'M.Tech Power Systems (Hons.), B.E Electrical, and the HT supervisory license.' },
  { href: `${base}/experience`, ic: '💼', title: 'Work Experience', desc: '132 kV bay extension, D/C transmission line, IPDS and tender / procurement roles.' },
  { href: `${base}/skills`, ic: '⚡', title: 'Skills & Capabilities', desc: 'Project execution, procurement, substation & line construction, MATLAB/Simulink.' },
  { href: `${base}/research`, ic: '📄', title: 'Published Research', desc: 'International journal paper on reactive-power compensation & voltage regulation.' },
  { href: `${base}/projects`, ic: '🔬', title: 'Academic Project', desc: 'Power-quality assessment using wavelet transform & substation reliability study.' },
  { href: 'tel:+919387975760', ic: '📞', title: 'Get in Touch', desc: 'Call or email to discuss your next electrical transmission or substation project.' },
];
---
<Layout>
  <!-- HERO -->
  <section class="hero">
    <div class="wrap">
      <h1 class="name"><span class="ln">Amlan</span><span class="ln">Kashyap</span></h1>
      <p class="tagline">Project Engineer — Electrical Transmission &amp; Substation Projects</p>

      <div class="idrow">
        <div class="avatar-ring"><img class="avatar" src={`${base}/profile.png`} alt="Amlan Kashyap" /></div>
        <div class="cred">
          <div class="role">Electrical Engineer</div>
          <div class="deg">B.E (Electrical Eng) · M.Tech (Electrical Power Systems)</div>
          <div class="loc">📍 Guwahati, Assam</div>
        </div>
      </div>

      <p class="intro">
        Electrical project engineer and <span class="lic">Electrical Supervisory License holder (HT, 33&nbsp;kV)</span>,
        with hands-on execution and procurement experience across <b>132&nbsp;kV substations and transmission lines</b>
        for AEGCL, APDCL, BHEL &amp; NTPC.
      </p>

      <div class="cta">
        <a class="btn btn-primary" href="tel:+919387975760">📞 +91 93879 75760</a>
        <a class="btn btn-ghost" href="mailto:amlanrickyaec77@gmail.com">✉ amlanrickyaec77@gmail.com</a>
      </div>

      <div class="stats">
        <div class="glass stat"><div class="v gradient-text">6+</div><div class="l">Years in electrical projects</div></div>
        <div class="glass stat"><div class="v gradient-text">4</div><div class="l">Utilities &amp; PSUs served</div></div>
        <div class="glass stat"><div class="v gradient-text">M.Tech</div><div class="l">Power Systems (Hons.)</div></div>
      </div>
    </div>
  </section>

  <!-- WORK EXPERIENCE -->
  <section class="block">
    <div class="wrap">
      <div class="shead"><div class="k">Experience</div><h2>Work <span class="gradient-text">experience</span></h2></div>
      <div class="jobs">
        <div class="glass job">
          <h3>Lead Project Manager — Execution &amp; Procurement</h3>
          <div class="co">Mega Electricals · Full-time</div>
          <p class="sum">Project manager for the complete execution and monitoring of AEGCL and APDCL transmission and substation projects.</p>
          <ul>
            <li><span class="b">▹</span> Construction of a new 132 kV bay extension at the 132/33 kV Barnagar Grid Substation (AEGCL).</li>
            <li><span class="b">▹</span> Construction of a 132 kV single-circuit line on D/C towers connecting Barnagar Grid Substation to Sorbhog Substation (AEGCL).</li>
            <li><span class="b">▹</span> Integrated Power Development Scheme (IPDS) — Karbi Anglong &amp; Hamren (APDCL).</li>
          </ul>
          <div class="tags">
            <span class="chip">AEGCL</span><span class="chip">APDCL</span><span class="chip">132 kV Bay Extension</span><span class="chip">D/C Transmission Line</span><span class="chip">IPDS</span>
          </div>
        </div>
        <div class="glass job">
          <h3>Project Engineer — Operations, Execution &amp; Procurement</h3>
          <div class="co">N.K. Engineering Works · Full-time</div>
          <p class="sum">Owned tender intelligence, bid submission and end-to-end project support across APDCL, BHEL and NTPC projects — from vendor approval to project closure.</p>
          <ul>
            <li><span class="b">▹</span> Explored tender notifications and shared relevant opportunities with the CEO.</li>
            <li><span class="b">▹</span> Arranged vendor-approval documentation and prepared / submitted bids with clients.</li>
            <li><span class="b">▹</span> Circulated Work Orders, Scope of Work, TCC, GCC &amp; SCC to project teams and stakeholders.</li>
            <li><span class="b">▹</span> Procured materials per scope &amp; approved specifications; ensured resource availability.</li>
            <li><span class="b">▹</span> Single point of contact for working groups; managed escalation, billing &amp; project closure.</li>
          </ul>
          <div class="tags">
            <span class="chip">APDCL</span><span class="chip">BHEL</span><span class="chip">NTPC</span><span class="chip">Tender / Bid Management</span><span class="chip">Procurement</span>
          </div>
        </div>
      </div>
    </div>
  </section>
  <div class="wrap"><div class="divider"></div></div>

  <!-- EDUCATION -->
  <section class="block">
    <div class="wrap">
      <div class="shead"><div class="k">Education</div><h2>Academic <span class="gradient-text">foundation</span></h2></div>
      <div class="edu">
        <div class="glass ecard">
          <div class="top"><span class="chip">2021 – 2023</span><span class="gr">78.47% · 1st Class with Honours</span></div>
          <h3>M.Tech — Electrical Engineering (Power Systems)</h3>
          <div class="sch">Assam Engineering College (AEC)</div>
          <div class="nt">Post-graduate specialisation in power systems.</div>
        </div>
        <div class="glass ecard">
          <div class="top"><span class="chip">2011 – 2015</span><span class="gr">66.24% · 1st Class</span></div>
          <h3>B.E — Electrical Engineering</h3>
          <div class="sch">Assam Engineering College (AEC)</div>
          <div class="nt">Final-year project on power-quality assessment &amp; substation reliability.</div>
        </div>
        <div class="glass licbox">
          <span class="ic">⚡</span>
          <span><b>Electrical Supervisory License holder (HT, 33 kV)</b> &nbsp;·&nbsp; <span>Authorised for high-tension electrical supervision only.</span></span>
        </div>
      </div>
    </div>
  </section>
  <div class="wrap"><div class="divider"></div></div>

  <!-- PROJECTS -->
  <section class="block">
    <div class="wrap">
      <div class="shead"><div class="k">Projects</div><h2>Academic <span class="gradient-text">project</span></h2></div>
      <div class="glass pcard">
        <h3>Power Quality Assessment using Wavelet Transform &amp; a Substation Reliability Case Study</h3>
        <div class="sub">Final-year project · Assam Engineering College</div>
        <div class="twocol" style="margin-top:18px">
          <div>
            <h4>7th Semester</h4>
            <ul>
              <li><span class="b">▹</span> Study of different power-quality disturbances using MATLAB.</li>
              <li><span class="b">▹</span> Power-quality analysis using DWT (Discrete Wavelet Transform) &amp; DT-DWT (Dual-Tree DWT), with results.</li>
            </ul>
          </div>
          <div>
            <h4>8th Semester</h4>
            <ul>
              <li><span class="b">▹</span> Neural network employed to classify the disturbances.</li>
              <li><span class="b">▹</span> Reliability case study of the 33/11 kV Ulubari distribution substation under APDCL.</li>
            </ul>
          </div>
        </div>
        <div class="tags"><span class="chip">MATLAB</span><span class="chip">Simulink</span><span class="chip">Neural Networks</span><span class="chip">Wavelet Transform</span></div>
      </div>
    </div>
  </section>
  <div class="wrap"><div class="divider"></div></div>

  <!-- RESEARCH PAPER -->
  <section class="block">
    <div class="wrap">
      <div class="shead"><div class="k">Research</div><h2>Published <span class="gradient-text">paper</span></h2></div>
      <div class="glass pcard">
        <span class="chip" style="margin-bottom:14px">International Journal · Peer-reviewed</span>
        <h3 style="max-width:880px;margin-top:6px">An Improved Control Strategy for Reactive-Power Compensation &amp; Voltage Regulation in Modern Distribution Networks</h3>
        <p style="max-width:820px">Research on advanced controller design for power-factor correction and demand-side management on the load side, benchmarked against a conventional smart-grid compensation approach — published in an international journal.</p>
        <div class="tags"><span class="chip">Power Factor Correction</span><span class="chip">Smart Grid</span><span class="chip">Demand-Side Management</span><span class="chip">Voltage Regulation</span></div>
      </div>
    </div>
  </section>
  <div class="wrap"><div class="divider"></div></div>

  <!-- EXPLORE -->
  <section class="explore">
    <div class="wrap">
      <div class="lead">
        <div class="k">Explore</div>
        <h2>Dive into the <span class="gradient-text">details</span></h2>
        <p>Each section opens its own page with full information.</p>
      </div>
      <div class="cards">
        {explore.map((c) => (
          <a class="glass lcard" href={c.href}>
            <div class="ic">{c.ic}</div><h3 set:html={c.title} />
            <p>{c.desc}</p>
            <span class="go">{c.href.startsWith('tel') ? 'Contact →' : 'Open page →'}</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
