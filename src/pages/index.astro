---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');

const stats = [
  { value: '6+', label: 'Years in electrical projects' },
  { value: '132 kV', label: 'Substation & line voltage class' },
  { value: '4', label: 'Utilities & PSUs served' },
  { value: 'M.Tech', label: 'Power Systems (Hons.)' },
];

const clients = ['AEGCL', 'APDCL', 'BHEL', 'NTPC'];

const experience = [
  {
    role: 'Lead Project Manager — Execution & Procurement',
    company: 'Mega Electricals',
    type: 'Full-time',
    period: 'Jun 2018 – May 2019 · 1 yr',
    place: 'Guwahati, Assam',
    summary:
      'Project manager for the complete execution and monitoring of AEGCL and APDCL transmission and substation projects.',
    points: [
      'Construction of a new 132 kV bay extension at the 132/33 kV Barnagar Grid Substation (AEGCL).',
      'Construction of a 132 kV single-circuit line on D/C towers connecting Barnagar Grid Substation to Sorbhog Substation (AEGCL).',
      'Integrated Power Development Scheme (IPDS) — Karbi Anglong & Hamren (APDCL).',
    ],
    tags: ['AEGCL', 'APDCL', '132 kV Bay Extension', 'D/C Transmission Line', 'IPDS'],
  },
  {
    role: 'Project Engineer — Operations, Execution & Procurement',
    company: 'N.K. Engineering Works',
    type: 'Full-time',
    period: 'Mar 2021 – Jul 2022 · 1 yr 5 mos',
    place: 'Guwahati, Assam',
    summary:
      'Owned tender intelligence, bid submission and end-to-end project support across APDCL, BHEL and NTPC projects — from vendor approval to project closure.',
    points: [
      'Explored tender notifications for relevant projects and shared opportunities with the CEO.',
      'Arranged vendor-approval documentation and prepared / submitted bids in coordination with clients.',
      'Circulated Work Orders, Scope of Work, TCC, GCC & SCC to project teams and stakeholders.',
      'Built in-depth understanding of project scope — timeframes, financials and outcomes.',
      'Ensured resources, equipment and materials were procured per scope and approved specifications.',
      'Single point of contact for working groups; managed escalation and review processes.',
      'Maintained thorough project documentation, reports, billing coordination and timely project closure.',
    ],
    tags: ['APDCL', 'BHEL', 'NTPC', 'Tender / Bid Management', 'Procurement', 'Stakeholder Coordination'],
  },
];

const education = [
  {
    degree: 'M.Tech — Electrical Engineering (Power Systems)',
    school: 'Assam Engineering College (AEC)',
    years: '2021 – 2023',
    grade: '78.47% · 1st Class with Honours',
    note: 'Post-graduate specialisation in power systems.',
  },
  {
    degree: 'B.E — Electrical Engineering',
    school: 'Assam Engineering College (AEC)',
    years: '2011 – 2015',
    grade: '66.24% · 1st Class',
    note: 'One-year final-year project on power-quality assessment & substation reliability.',
  },
];

const skillGroups = [
  {
    title: 'Project & Commercial',
    items: ['Project Execution & Monitoring', 'Procurement & Vendor Management', 'Tender / Bid Management', 'Contract Documentation (TCC / GCC / SCC)', 'Stakeholder Coordination'],
  },
  {
    title: 'Electrical Engineering',
    items: ['132 kV Substation & Bay Extension', 'Transmission Line Construction (D/C Tower)', 'IPDS Implementation', 'Power Quality Analysis (DWT)', 'AEGCL / APDCL / BHEL / NTPC Standards'],
  },
  {
    title: 'Technical & Analysis',
    items: ['MATLAB', 'Simulink', 'Neural Networks', 'Wavelet Transform (DWT / DT-DWT)', 'Reliability Studies'],
  },
];
---

<Layout>
  <!-- ============ HERO ============ -->
  <section class="relative pt-40 pb-20 sm:pt-48 sm:pb-28">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <div class="grid lg:grid-cols-[1.4fr_1fr] gap-12 lg:gap-16 items-center">
        <div class="reveal">
          <div class="inline-flex items-center gap-2.5 mb-7 px-4 py-2 rounded-full border border-[#1b2940] bg-[#0b1220]/60">
            <span class="w-2 h-2 rounded-full bg-[#a3e635] pulse"></span>
            <span class="text-sm text-[#8da2bd]">Open to electrical project management roles</span>
          </div>

          <h1 class="text-5xl sm:text-6xl lg:text-7xl font-bold leading-[1.02]">
            Amlan<br /><span class="gradient-text">Kashyap</span>
          </h1>

          <p class="mt-6 text-xl sm:text-2xl font-medium text-[#cdd9e8]" style="font-family:'Space Grotesk'">
            Project Manager — Electrical Transmission &amp; Substation Projects
          </p>

          <p class="mt-5 max-w-xl text-[#8da2bd] leading-relaxed">
            Electrical project manager with hands-on execution and procurement experience across
            <span class="text-[#cdd9e8]">132 kV substations and transmission lines</span> for
            AEGCL, APDCL, BHEL &amp; NTPC.
          </p>

          <div class="mt-9 flex flex-wrap gap-4">
            <a href="tel:+919387975760" class="btn btn-primary">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              +91 93879 75760
            </a>
            <a href="#experience" class="btn btn-ghost">View experience</a>
          </div>
        </div>

        <!-- profile -->
        <div class="reveal flex justify-center lg:justify-end">
          <div class="relative">
            <div class="absolute -inset-3 rounded-[28px] bg-gradient-to-br from-[#22d3ee]/40 via-transparent to-[#a3e635]/30 blur-xl"></div>
            <div class="relative rounded-[24px] p-1.5 bg-gradient-to-br from-[#22d3ee] via-[#2dd4bf] to-[#a3e635]">
              <div class="rounded-[18px] overflow-hidden bg-[#0b1220]">
                <img src={`${base}/profile.png`} alt="Amlan Kashyap" class="w-[300px] sm:w-[340px] h-auto object-cover" />
              </div>
            </div>
            <div class="absolute -bottom-5 -left-5 card px-5 py-3 bg-[#0b1220]">
              <p class="text-2xl font-bold gradient-text" style="font-family:'Space Grotesk'">132 kV</p>
              <p class="text-xs text-[#8da2bd]">Substation & line class</p>
            </div>
          </div>
        </div>
      </div>

      <!-- stats -->
      <div class="reveal mt-20 grid grid-cols-2 lg:grid-cols-4 gap-4">
        {stats.map((s) => (
          <div class="card p-6">
            <p class="text-3xl sm:text-4xl font-bold gradient-text" style="font-family:'Space Grotesk'">{s.value}</p>
            <p class="mt-2 text-sm text-[#8da2bd]">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CLIENT MARQUEE ============ -->
  <section class="py-8 border-y border-[#1b2940] overflow-hidden">
    <div class="max-w-6xl mx-auto px-5 sm:px-8 mb-5">
      <p class="text-center text-xs tracking-[0.28em] uppercase text-[#8da2bd]">Utilities & PSUs delivered for</p>
    </div>
    <div class="marquee-track">
      {[...clients, ...clients, ...clients, ...clients].map((c) => (
        <span class="text-3xl sm:text-4xl font-bold text-[#2a3a55] hover:text-[#22d3ee] transition" style="font-family:'Space Grotesk'">{c}</span>
      ))}
    </div>
  </section>

  <!-- ============ ABOUT ============ -->
  <section id="about" class="py-24">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <div class="grid lg:grid-cols-[0.8fr_1.2fr] gap-12">
        <div class="reveal">
          <p class="sec-label">About</p>
          <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Building &amp; energising<br /><span class="gradient-text">the grid.</span></h2>
        </div>
        <div class="reveal space-y-5 text-lg text-[#a9b8cc] leading-relaxed">
          <p>
            I am an electrical engineer and project manager focused on the
            <span class="text-[#e6edf6]">construction and extension of high-voltage substations and transmission lines</span>.
            My work spans the full project lifecycle — from tendering and procurement through execution, monitoring and commissioning.
          </p>
          <p>
            I have led the execution of a <span class="text-[#e6edf6]">132 kV bay extension</span> and a
            <span class="text-[#e6edf6]">132 kV single-circuit D/C-tower line</span> for AEGCL, delivered IPDS works for APDCL, and
            managed bids, vendor approvals and documentation across APDCL, BHEL and NTPC projects.
          </p>
          <p>
            Backed by an <span class="text-[#e6edf6]">M.Tech in Power Systems (1st Class with Honours)</span> and a published
            international research paper, I combine field execution with strong technical fundamentals.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ EXPERIENCE ============ -->
  <section id="experience" class="py-24 border-t border-[#1b2940]">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <div class="reveal mb-14">
        <p class="sec-label">Experience</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Project execution track record</h2>
      </div>

      <div class="relative pl-6 sm:pl-8 border-l border-[#1b2940] space-y-12">
        {experience.map((job) => (
          <div class="reveal relative">
            <span class="tl-dot absolute -left-[33px] sm:-left-[41px] top-1.5 w-4 h-4 rounded-full bg-gradient-to-br from-[#22d3ee] to-[#a3e635]"></span>
            <div class="card p-7 sm:p-8">
              <div class="flex flex-wrap items-start justify-between gap-3">
                <div>
                  <h3 class="text-xl sm:text-2xl font-semibold text-[#e6edf6]">{job.role}</h3>
                  <p class="mt-1 text-[#22d3ee] font-medium">{job.company} <span class="text-[#8da2bd] font-normal">· {job.type}</span></p>
                </div>
                <div class="text-right">
                  <p class="text-sm text-[#cdd9e8]">{job.period}</p>
                  <p class="text-xs text-[#8da2bd]">{job.place}</p>
                </div>
              </div>
              <p class="mt-4 text-[#a9b8cc] leading-relaxed">{job.summary}</p>
              <ul class="mt-5 space-y-3">
                {job.points.map((p) => (
                  <li class="flex gap-3 text-[#a9b8cc]">
                    <svg class="mt-1.5 shrink-0" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#22d3ee" stroke-width="3"><path d="M5 12l5 5L20 7"/></svg>
                    <span>{p}</span>
                  </li>
                ))}
              </ul>
              <div class="mt-6 flex flex-wrap gap-2.5">
                {job.tags.map((t) => <span class="chip">{t}</span>)}
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ EDUCATION ============ -->
  <section id="education" class="py-24 border-t border-[#1b2940]">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <div class="reveal mb-14">
        <p class="sec-label">Education</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Academic foundation</h2>
      </div>

      <div class="grid md:grid-cols-2 gap-5 mb-10">
        {education.map((e) => (
          <div class="reveal card p-7">
            <div class="flex items-center justify-between">
              <span class="chip !py-1.5 !px-3 text-xs">{e.years}</span>
              <span class="text-xs font-medium text-[#a3e635]">{e.grade}</span>
            </div>
            <h3 class="mt-4 text-xl font-semibold text-[#e6edf6]">{e.degree}</h3>
            <p class="mt-1 text-[#22d3ee]">{e.school}</p>
            <p class="mt-3 text-sm text-[#8da2bd]">{e.note}</p>
          </div>
        ))}
      </div>

      <!-- Academic project -->
      <div class="reveal card p-7 sm:p-9">
        <div class="flex items-center gap-3 mb-2">
          <span class="grid place-items-center w-10 h-10 rounded-lg bg-[#0b1220] border border-[#1b2940]">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#22d3ee" stroke-width="2"><path d="M3 3v18h18M7 14l4-4 3 3 5-6"/></svg>
          </span>
          <p class="sec-label !text-[11px]">Final-year project · AEC</p>
        </div>
        <h3 class="text-xl sm:text-2xl font-semibold text-[#e6edf6]">Power Quality Assessment using Wavelet Transform &amp; a Substation Reliability Case Study</h3>
        <div class="mt-6 grid sm:grid-cols-2 gap-6">
          <div>
            <p class="text-sm font-semibold text-[#22d3ee] mb-2">7th Semester</p>
            <ul class="space-y-2 text-[#a9b8cc] text-sm">
              <li class="flex gap-2.5"><span class="text-[#a3e635]">▹</span> Study of different power-quality disturbances using MATLAB.</li>
              <li class="flex gap-2.5"><span class="text-[#a3e635]">▹</span> Power-quality analysis using DWT (Discrete Wavelet Transform) and DT-DWT (Dual-Tree DWT), with results.</li>
            </ul>
          </div>
          <div>
            <p class="text-sm font-semibold text-[#22d3ee] mb-2">8th Semester</p>
            <ul class="space-y-2 text-[#a9b8cc] text-sm">
              <li class="flex gap-2.5"><span class="text-[#a3e635]">▹</span> Neural network employed to classify the disturbances.</li>
              <li class="flex gap-2.5"><span class="text-[#a3e635]">▹</span> Reliability case study of the 33/11 kV Ulubari distribution substation under APDCL.</li>
            </ul>
          </div>
        </div>
        <div class="mt-6 flex flex-wrap gap-2.5">
          {['MATLAB', 'Simulink', 'Neural Networks', 'Wavelet Transform'].map((t) => <span class="chip">{t}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- ============ SKILLS ============ -->
  <section id="skills" class="py-24 border-t border-[#1b2940]">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <div class="reveal mb-14">
        <p class="sec-label">Skills</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Capabilities</h2>
      </div>
      <div class="grid md:grid-cols-3 gap-5">
        {skillGroups.map((g) => (
          <div class="reveal card p-7">
            <h3 class="text-lg font-semibold text-[#e6edf6] mb-5">{g.title}</h3>
            <div class="flex flex-wrap gap-2.5">
              {g.items.map((i) => <span class="chip">{i}</span>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ RESEARCH ============ -->
  <section id="research" class="py-24 border-t border-[#1b2940]">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <div class="reveal mb-14">
        <p class="sec-label">Research</p>
        <h2 class="mt-3 text-3xl sm:text-4xl font-bold">Published work</h2>
      </div>
      <div class="reveal card p-8 sm:p-10 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-56 h-56 bg-[#22d3ee]/10 blur-3xl rounded-full"></div>
        <div class="relative">
          <span class="chip !py-1.5 text-xs mb-5">International Journal · Peer-reviewed</span>
          <h3 class="text-2xl sm:text-3xl font-semibold text-[#e6edf6] max-w-3xl leading-snug">
            An Improved Control Strategy for Reactive-Power Compensation &amp; Voltage Regulation in Modern Distribution Networks
          </h3>
          <p class="mt-5 max-w-2xl text-[#a9b8cc] leading-relaxed">
            Research on advanced controller design for power-factor correction and demand-side management on the load side,
            benchmarked against a conventional smart-grid compensation approach — published in an international journal.
          </p>
          <div class="mt-7 flex flex-wrap gap-2.5">
            {['Power Factor Correction', 'Smart Grid', 'Demand-Side Management', 'Voltage Regulation'].map((t) => <span class="chip">{t}</span>)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ CONTACT ============ -->
  <section id="contact" class="py-24 border-t border-[#1b2940]">
    <div class="max-w-6xl mx-auto px-5 sm:px-8">
      <div class="reveal card p-10 sm:p-16 text-center relative overflow-hidden">
        <div class="absolute -top-20 left-1/2 -translate-x-1/2 w-[460px] h-[460px] bg-[#22d3ee]/12 blur-3xl rounded-full"></div>
        <div class="relative">
          <p class="sec-label">Get in touch</p>
          <h2 class="mt-4 text-3xl sm:text-5xl font-bold max-w-2xl mx-auto leading-tight">
            Let's discuss your next <span class="gradient-text">electrical project</span>.
          </h2>
          <p class="mt-5 text-[#8da2bd]">Based in Guwahati, Assam · Available across the North-East &amp; PAN India.</p>
          <div class="mt-9 flex flex-col sm:flex-row gap-4 justify-center items-center">
            <a href="tel:+919387975760" class="btn btn-primary text-lg !py-4 !px-8">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.36 1.9.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.34 1.85.57 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              +91 93879 75760
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
