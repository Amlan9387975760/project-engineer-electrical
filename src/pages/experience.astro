---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Experience — Amlan Kashyap">
  <section class="page-head">
    <div class="wrap">
      <a class="backlink" href={`${base}/`}>← Back to home</a>
      <h1>Work <span class="gradient-text">Experience</span></h1>
      <p class="sub">Execution, monitoring and procurement of high-voltage transmission and substation projects for AEGCL, APDCL, BHEL and NTPC.</p>
    </div>
  </section>

  <section class="block" style="padding-top:24px">
    <div class="wrap">
      <div class="jobs">
        <div class="glass job">
          <h3>Lead Project Manager — Execution &amp; Procurement</h3>
          <div class="co">Mega Electricals · Full-time</div>
          <p class="sum">Project manager for the complete execution and monitoring of AEGCL and APDCL transmission and substation projects.</p>
          <ul>
            <li><span class="b">▹</span> Construction of a new 132 kV bay extension at the 132/33 kV Barnagar Grid Substation (AEGCL).</li>
            <li><span class="b">▹</span> Construction of a 132 kV single-circuit line on D/C towers connecting Barnagar Grid Substation to Sorbhog Substation (AEGCL).</li>
            <li><span class="b">▹</span> Integrated Power Development Scheme (IPDS) — Karbi Anglong &amp; Hamren (APDCL).</li>
          </ul>
          <div class="tags">
            <span class="chip">AEGCL</span><span class="chip">APDCL</span><span class="chip">132 kV Bay Extension</span><span class="chip">D/C Transmission Line</span><span class="chip">IPDS</span>
          </div>
        </div>
        <div class="glass job">
          <h3>Project Engineer — Operations, Execution &amp; Procurement</h3>
          <div class="co">N.K. Engineering Works · Full-time</div>
          <p class="sum">Owned tender intelligence, bid submission and end-to-end project support across APDCL, BHEL and NTPC projects — from vendor approval to project closure.</p>
          <ul>
            <li><span class="b">▹</span> Explored tender notifications and shared relevant opportunities with the CEO.</li>
            <li><span class="b">▹</span> Arranged vendor-approval documentation and prepared / submitted bids in coordination with clients.</li>
            <li><span class="b">▹</span> Circulated Work Orders, Scope of Work, TCC, GCC &amp; SCC to project teams and stakeholders.</li>
            <li><span class="b">▹</span> Built in-depth understanding of project scope — timeframes, financials and outcomes.</li>
            <li><span class="b">▹</span> Procured materials per scope &amp; approved specifications; ensured resources and equipment were available.</li>
            <li><span class="b">▹</span> Single point of contact for working groups; managed escalation and review processes.</li>
            <li><span class="b">▹</span> Maintained thorough documentation, reports, billing coordination and timely project closure.</li>
          </ul>
          <div class="tags">
            <span class="chip">APDCL</span><span class="chip">BHEL</span><span class="chip">NTPC</span><span class="chip">Tender / Bid Management</span><span class="chip">Procurement</span><span class="chip">Stakeholder Coordination</span>
          </div>
        </div>
      </div>
    </div>
  </section>
</Layout>
