---
import Layout from '../layouts/Layout.astro';
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<Layout title="Education — Amlan Kashyap">
  <section class="page-head">
    <div class="wrap">
      <a class="backlink" href={`${base}/`}>← Back to home</a>
      <h1>Education &amp; <span class="gradient-text">Credentials</span></h1>
      <p class="sub">Postgraduate specialisation in power systems, a first-class engineering degree, and a high-tension electrical supervisory licence.</p>
    </div>
  </section>

  <section class="block" style="padding-top:24px">
    <div class="wrap">
      <div class="edu">
        <div class="glass ecard">
          <div class="top"><span class="chip">2021 – 2023</span><span class="gr">78.47% · 1st Class with Honours</span></div>
          <h3>M.Tech — Electrical Engineering (Power Systems)</h3>
          <div class="sch">Assam Engineering College (AEC)</div>
          <div class="nt">Post-graduate specialisation in power systems — power flow, protection, quality and reliability of transmission &amp; distribution networks.</div>
        </div>
        <div class="glass ecard">
          <div class="top"><span class="chip">2011 – 2015</span><span class="gr">66.24% · 1st Class</span></div>
          <h3>B.E — Electrical Engineering</h3>
          <div class="sch">Assam Engineering College (AEC)</div>
          <div class="nt">Final-year project on power-quality assessment using wavelet transform and a substation reliability case study.</div>
        </div>
        <div class="glass licbox">
          <span class="ic">⚡</span>
          <span><b>Electrical Supervisory License holder (HT, 33 kV)</b></span>
        </div>
      </div>
    </div>
  </section>
</Layout>
